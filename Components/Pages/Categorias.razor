@page "/categorias"
@page "/categorias/{CatName}"
@inject FormulaService Fs
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using System.Linq
@implements IDisposable

@if (string.IsNullOrEmpty(CatName))
{
    <!-- All categories -->
    <div class="section-header">
        <div class="section-title">Categorias</div>
        <div class="section-sub">@Fs.ObterCategorias().Count() áreas do conhecimento · @Fs.ObterTotalFormulas() fórmulas</div>
    </div>

    <div class="cat-grid" style="padding:12px 16px">
        @foreach (var cat in Fs.ObterCategorias())
        {
            <div class="cat-card"
                 style="--cat-color: @cat.Cor"
                 @onclick='() => Nav.NavigateTo($"/categorias/{Uri.EscapeDataString(cat.Nome)}")'>
                <div class="cat-icon">@cat.Icone</div>
                <div class="cat-name">@cat.Nome</div>
                <div class="cat-count">@cat.TotalFormulas fórmulas</div>
            </div>
        }
    </div>
}
else
{
    <!-- Formulas in category -->
    var decoded = Uri.UnescapeDataString(CatName);
    var catInfo  = Fs.ObterCategorias().FirstOrDefault(c => c.Nome == decoded);

    <div style="padding:12px 16px 4px; display:flex; align-items:center; gap:10px">
        <button style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;padding:4px"
                @onclick='() => Nav.NavigateTo("/categorias")'>←</button>
        <div>
            <div style="font-family:var(--font-display);font-size:22px;font-weight:600;color:var(--text-primary)">
                @(catInfo != null ? catInfo.Icone + " " : "")@decoded
            </div>
            <div style="font-size:12px;color:var(--text-secondary)">@_totalCategoria fórmulas</div>
        </div>
    </div>

    <div class="cat-filters" style="padding:8px 16px 4px">
        <div class="cat-filter-item">
            <label class="cat-filter-label">Subcategoria</label>
            <select class="cat-filter-select" value="@_filtroSubCategoria" @onchange="OnFiltroSubcategoriaChanged">
                <option value="">Todas</option>
                @foreach (var s in _subCategorias)
                {
                    <option value="@s">@s</option>
                }
            </select>
        </div>
        <div class="cat-filter-item">
            <label class="cat-filter-label">Origem histórica</label>
            <select class="cat-filter-select" value="@_filtroOrigem" @onchange="OnFiltroOrigemChanged">
                <option value="">Todas</option>
                @foreach (var o in _origensHistoricas)
                {
                    <option value="@o">@o</option>
                }
            </select>
        </div>
        <div class="cat-filter-item">
            <label class="cat-filter-label">Criador</label>
            <input class="cat-filter-select"
                   type="text"
                   list="criadores-list"
                   placeholder="Digite para buscar criador..."
                   value="@_filtroCriador"
                   @oninput="OnFiltroCriadorChanged" />
            <datalist id="criadores-list">
                @foreach (var c in _criadores)
                {
                    <option value="@c"></option>
                }
            </datalist>
        </div>
    </div>

    <div class="formula-list">
        <Virtualize @ref="_virtualizeRef" Context="f" ItemsProvider="CarregarPaginaCategoria" ItemSize="188" OverscanCount="4">
            <ItemContent>
                <div class="virtual-formula-item">
                    <div class="formula-card formula-card-fixed" @onclick='() => Nav.NavigateTo($"/formula/{f.Id}")'>
                        <div class="formula-card-top">
                            <div class="formula-icon">@f.Icone</div>
                            <div class="formula-meta">
                                <div class="formula-name">@f.Nome</div>
                                <div class="formula-author">@f.Criador</div>
                            </div>
                            <button class="formula-fav-btn @(f.Favorita ? "active" : "")"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => ToggleFav(f)">
                                @(f.Favorita ? "★" : "☆")
                            </button>
                        </div>
                        <div class="formula-expr">@f.ExprTexto</div>
                        <div class="formula-desc">@f.Descricao</div>
                    </div>
                </div>
            </ItemContent>
        </Virtualize>
    </div>
}

@code {
    [Parameter] public string? CatName { get; set; }
    int _totalCategoria;
    string _filtroSubCategoria = "";
    string _filtroOrigem = "";
    string _filtroCriador = "";
    List<string> _subCategorias = [];
    List<string> _origensHistoricas = [];
    List<string> _criadores = [];
    Virtualize<Formula>? _virtualizeRef;
    CancellationTokenSource? _debounceCts;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(CatName))
        {
            _totalCategoria = 0;
            _subCategorias = [];
            _origensHistoricas = [];
            _criadores = [];
            _filtroSubCategoria = "";
            _filtroOrigem = "";
            _filtroCriador = "";
            return;
        }

        var decoded = Uri.UnescapeDataString(CatName);
        _subCategorias = Fs.ObterSubCategoriasPorCategoria(decoded).ToList();
        _origensHistoricas = Fs.ObterOrigensHistoricasPorCategoria(decoded).ToList();
        _criadores = Fs.ObterCriadoresPorCategoria(decoded).ToList();
        _totalCategoria = Fs.ObterTotalPorCategoriaFiltrado(decoded, _filtroSubCategoria, _filtroOrigem, _filtroCriador);
    }

    void ToggleFav(Formula f) {
        Fs.ToggleFavorita(f.Id);
        StateHasChanged();
    }

    async Task OnFiltroSubcategoriaChanged(ChangeEventArgs e)
    {
        _filtroSubCategoria = e.Value?.ToString() ?? "";
        await AtualizarFiltroAsync();
    }

    async Task OnFiltroOrigemChanged(ChangeEventArgs e)
    {
        _filtroOrigem = e.Value?.ToString() ?? "";
        await AtualizarFiltroAsync();
    }

    async Task OnFiltroCriadorChanged(ChangeEventArgs e)
    {
        _filtroCriador = e.Value?.ToString() ?? "";
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;
        try
        {
            await Task.Delay(250, token);
            await AtualizarFiltroAsync();
        }
        catch (OperationCanceledException) { }
    }

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
    }

    async Task AtualizarFiltroAsync()
    {
        if (string.IsNullOrWhiteSpace(CatName))
        {
            _totalCategoria = 0;
            return;
        }

        var decoded = Uri.UnescapeDataString(CatName);
        _totalCategoria = Fs.ObterTotalPorCategoriaFiltrado(decoded, _filtroSubCategoria, _filtroOrigem, _filtroCriador);
        if (_virtualizeRef is not null)
        {
            await _virtualizeRef.RefreshDataAsync();
        }
        StateHasChanged();
    }

    ValueTask<ItemsProviderResult<Formula>> CarregarPaginaCategoria(ItemsProviderRequest request)
    {
        if (string.IsNullOrWhiteSpace(CatName))
        {
            return ValueTask.FromResult(new ItemsProviderResult<Formula>([], 0));
        }

        var decoded = Uri.UnescapeDataString(CatName);
        var itens = Fs.ObterPorCategoriaPaginadoFiltrado(decoded, request.StartIndex, request.Count, _filtroSubCategoria, _filtroOrigem, _filtroCriador).ToList();
        return ValueTask.FromResult(new ItemsProviderResult<Formula>(itens, _totalCategoria));
    }
}
