@inject AccessibilityService AccessibilityService
@implements IDisposable

@if (_showNotification)
{
    <div class="accessibility-notification @(_isVisible ? "visible" : "")" role="alert" aria-live="polite">
        <div class="notification-icon">✓</div>
        <div class="notification-message">@_message</div>
    </div>
}

<style>
    .accessibility-notification {
        position: fixed;
        bottom: 80px;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        background: var(--gold);
        color: var(--bg-base);
        padding: 12px 24px;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
        z-index: 1000;
        opacity: 0;
        transition: all 0.3s ease;
        pointer-events: none;
    }

    .accessibility-notification.visible {
        transform: translateX(-50%) translateY(0);
        opacity: 1;
    }

    body.reduce-motion .accessibility-notification {
        transition: none;
    }

    .notification-icon {
        font-size: 20px;
        line-height: 1;
    }

    .notification-message {
        font-size: 14px;
        letter-spacing: 0.02em;
    }
</style>

@code {
    private bool _showNotification = false;
    private bool _isVisible = false;
    private string _message = "";
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        AccessibilityService.OnSettingsChanged += HandleSettingsChanged;
    }

    private async void HandleSettingsChanged()
    {
        var settings = AccessibilityService.CurrentSettings;
        
        // Determinar mensagem baseada nas configurações atuais
        _message = GetNotificationMessage(settings);
        
        // Mostrar notificação
        _showNotification = true;
        StateHasChanged();
        
        // Pequeno delay para animação
        await Task.Delay(50);
        _isVisible = true;
        StateHasChanged();
        
        // Esconder após 3 segundos
        _timer?.Dispose();
        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                _isVisible = false;
                StateHasChanged();
                
                await Task.Delay(300);
                _showNotification = false;
                StateHasChanged();
            });
        }, null, 3000, System.Threading.Timeout.Infinite);
    }

    private string GetNotificationMessage(AccessibilityService.AccessibilitySettings settings)
    {
        if (!settings.DarkMode)
            return "Modo claro ativado";
        
        if (settings.DarkMode && !settings.HighContrast)
            return "Modo escuro ativado";
        
        if (settings.HighContrast)
            return "Alto contraste ativado";
        
        if (settings.SimplifiedMode)
            return "Modo simplificado ativado";
        
        if (settings.LargerButtons)
            return "Botões maiores ativados";
        
        if (settings.FontSizePercentage > 100)
            return $"Tamanho de fonte: {settings.FontSizePercentage}%";
        
        return "Configurações atualizadas";
    }

    public void Dispose()
    {
        AccessibilityService.OnSettingsChanged -= HandleSettingsChanged;
        _timer?.Dispose();
    }
}
