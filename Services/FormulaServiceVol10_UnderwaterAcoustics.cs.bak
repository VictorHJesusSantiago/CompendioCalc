using CompendioCalc.Models;
using System;
using System.Collections.Generic;

namespace CompendioCalc.Services
{
    /// <summary>
    /// VOLUME X - PARTE XII
    /// ACÚSTICA SUBAQUÁTICA, SONAR E OCEANOGRAFIA ACÚSTICA
    /// Fórmulas V10-220 a V10-238 (19 fórmulas)
    /// </summary>
    public partial class FormulaService
    {
        private void AdicionarFormulasVol10_UnderwaterAcoustics()
        {
            _formulas.AddRange(new List<Formula>
            {
                new Formula
                {
                    Id = 3808,
                    CodigoCompendio = "V10-220",
                    Nome = "Equação de Sonar — Nível de Sinal",
                    Categoria = "Acústica Subaquática",
                    SubCategoria = "Sistemas Sonar",
                    Nivel = "Avançado",
                    Expressao = @"SL − 2TL + TS − (NL − DI) = DT",
                    Descricao = "SL: source level. TL: transmission loss. TS: target strength. NL: noise level. DI: directivity index. DT: detection threshold.",
                    ExemploUso = "Sonar ativo: SL=220dB, TL=70dB, TS=20dB, NL=80dB, DI=20dB → SNR=20dB. Detecção possível se SNR>DT.",
                    Origem = "Urick (1983, Principles of Underwater Sound)",
                    AnoOrigem = "1983",
                    Variaveis = new List<Variavel>
                    {
                        new Variavel { Nome = "Source Level SL (dB)", Simbolo = "SL", Unidade = "dB", Valor = 220 },
                        new Variavel { Nome = "Transmission Loss TL (dB)", Simbolo = "TL", Unidade = "dB", Valor = 70 },
                        new Variavel { Nome = "Target Strength TS (dB)", Simbolo = "TS", Unidade = "dB", Valor = 20 }
                    },
                    Calcular = inputs =>
                    {
                        double SL = inputs["Source Level SL (dB)"];
                        double TL = inputs["Transmission Loss TL (dB)"];
                        double TS = inputs["Target Strength TS (dB)"];
                        
                        double NL = 80; // Típico
                        double DI = 20; // Típico
                        double DT = 10; // Threshold típico
                        
                        double SNR = SL - 2 * TL + TS - (NL - DI);
                        double detectavel = SNR > DT ? 1 : 0;
                        
                        return new Dictionary<string, double>{
                            ["SNR (dB)"] = SNR,
                            ["Detectável?"] = detectavel,
                            ["Margem sobre DT (dB)"] = SNR - DT
                        };
                    },
                    Icone = "🌊"
                }
                // Demais fórmulas V10-221 a V10-238
            });
        }
    }
}
