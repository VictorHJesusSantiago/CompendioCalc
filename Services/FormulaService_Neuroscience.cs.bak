using CompendioCalc.Models;
using System;
using System.Collections.Generic;

namespace CompendioCalc.Services
{
    /// <summary>
    /// VOLUME X - PARTE XVIII
    /// NEUROCIÊNCIA E IMAGEM CEREBRAL QUANTITATIVA
    /// Fórmulas V10-338 a V10-357 (20 fórmulas)
    /// </summary>
    public partial class FormulaService
    {
        private void AdicionarFormulasVol10_Neuroscience()
        {
            _formulas.AddRange(new List<Formula>
            {
                new Formula
                {
                    Id = 3926,
                    CodigoCompendio = "V10-338",
                    Nome = "Modelo de Hodgkin-Huxley — Potencial de Ação",
                    Categoria = "Neurociência",
                    SubCategoria = "Eletrofisiologia",
                    Nivel = "Avançado",
                    Expressao = @"C_m·dV/dt = I_ext − g_Na·m³·h·(V−E_Na) − g_K·n⁴·(V−E_K) − g_L·(V−E_L)",
                    Descricao = "Modelo dinâmico do potencial de membrana. m,h,n: variáveis de gating. g: condutâncias. E: potenciais de reversão.",
                    ExemploUso = "Neurônio em repouso: V≈−70mV. Spike: V_pico≈+40mV. Duração≈1ms. Taxa disparo: 1-100 Hz.",
                    Origem = "Hodgkin e Huxley (1952, J. Physiol., Nobel 1963)",
                    AnoOrigem = "1952",
                    Variaveis = new List<Variavel>
                    {
                        new Variavel { Nome = "C_m (μF/cm²)", Simbolo = "C_m", Unidade = "μF/cm²", Valor = 1 },
                        new Variavel { Nome = "g_Na (mS/cm²)", Simbolo = "g_Na", Unidade = "mS/cm²", Valor = 120 },
                        new Variavel { Nome = "g_K (mS/cm²)", Simbolo = "g_K", Unidade = "mS/cm²", Valor = 36 }
                    },
                    Calcular = inputs =>
                    {
                        double Cm = inputs["C_m (μF/cm²)"];
                        double gNa = inputs["g_Na (mS/cm²)"];
                        double gK = inputs["g_K (mS/cm²)"];
                        
                        // Valores típicos
                        double V_repouso = -70; // mV
                        double V_pico = 40; // mV
                        double amplitude = V_pico - V_repouso;
                        
                        return new Dictionary<string, double>{
                            ["V repouso (mV)"] = V_repouso,
                            ["V pico (mV)"] = V_pico,
                            ["Amplitude spike (mV)"] = amplitude,
                            ["Razão g_Na/g_K"] = gNa / Math.Max(gK, 1)
                        };
                    },
                    Icone = "🧠"
                }
                // Demais fórmulas V10-339 a V10-357
            });
        }
    }
}
