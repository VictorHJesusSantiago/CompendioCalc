@inject IJSRuntime JS
@inject AccessibilityService AccessibilityService
@implements IDisposable

@code {
    private bool _isInitialized = false;
    private int _retryCount = 0;
    private const int MaxRetries = 5;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Aguarda o JavaScript carregar completamente
            await Task.Delay(200);
            
            // Tenta inicializar com retry
            await InitializeWithRetry();
        }
    }

    private async Task InitializeWithRetry()
    {
        while (_retryCount < MaxRetries && !_isInitialized)
        {
            try
            {
                // Verifica se o accessibilityManager está disponível
                var isReady = await JS.InvokeAsync<bool>("eval", 
                    "typeof window.accessibilityManager !== 'undefined' && typeof window.accessibilityManager.isReady === 'function' && window.accessibilityManager.isReady()");
                
                if (isReady)
                {
                    Console.WriteLine($"[Accessibility] JavaScript pronto! Aplicando configurações...");
                    await ApplySettings();
                    _isInitialized = true;
                    return;
                }
                else
                {
                    _retryCount++;
                    Console.WriteLine($"[Accessibility] JavaScript não pronto. Tentativa {_retryCount}/{MaxRetries}");
                    await Task.Delay(500);
                }
            }
            catch (Exception ex)
            {
                _retryCount++;
                Console.WriteLine($"[Accessibility] Erro na tentativa {_retryCount}: {ex.Message}");
                await Task.Delay(500);
            }
        }
        
        if (!_isInitialized)
        {
            Console.WriteLine($"[Accessibility] FALHA: Não foi possível inicializar após {MaxRetries} tentativas");
        }
    }

    protected override void OnInitialized()
    {
        AccessibilityService.OnSettingsChanged += OnSettingsChanged;
    }

    private async void OnSettingsChanged()
    {
        if (_isInitialized)
        {
            await ApplySettings();
            StateHasChanged();
        }
        else
        {
            Console.WriteLine("[Accessibility] Settings changed mas ainda não inicializado");
        }
    }

    private async Task ApplySettings()
    {
        try
        {
            var classes = AccessibilityService.GetAccessibilityCssClass();
            var fontSize = AccessibilityService.CurrentSettings.FontSizePercentage;
            
            Console.WriteLine($"[Accessibility] ===== APLICANDO CONFIGURAÇÕES =====");
            Console.WriteLine($"[Accessibility] Classes: {classes}");
            Console.WriteLine($"[Accessibility] FontSize: {fontSize}%");
            
            // Chama função JavaScript global diretamente
            await JS.InvokeVoidAsync("window.accessibilityManager.applyAll", classes, fontSize);
            
            Console.WriteLine($"[Accessibility] Configurações aplicadas com sucesso!");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Accessibility] ❌ ERRO ao aplicar configurações: {ex.Message}");
            Console.WriteLine($"[Accessibility] Stack: {ex.StackTrace}");
        }
    }

    public void Dispose()
    {
        AccessibilityService.OnSettingsChanged -= OnSettingsChanged;
    }
}
